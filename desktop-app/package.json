{
  "name": "niladri-edu-pro",
  "version": "1.0.0",
  "description": "Niladri Edu Pro Desktop Launcher",
  "main": "main.js",
  "author": "Niladri",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.niladri.edupro",
    "productName": "Niladri Edu Pro",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Niladri Edu Pro"
    },
    "extraResources": [
      { "from": "resources/python",   "to": "python"   },
      { "from": "resources/backend",  "to": "backend"  },
      { "from": "resources/frontend", "to": "frontend" },
      { "from": "resources/postgres", "to": "postgres" }
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/**/*"
    ]
  }
}
