DATABASE_URL=postgresql://admin:CHANGE_ME_DB_PASSWORD@localhost:5432/niladri_db
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
REFRESH_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32_DIFFERENT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
LICENSE_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32_LICENSE
ENVIRONMENT=development

# For Docker Compose
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=niladri_db

# CORS (comma-separated list, override in production)
# CORS_ORIGINS=https://yourapp.example.com

# Fernet key for backup encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# BACKUP_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# Set ENVIRONMENT=production when deploying with HTTPS to enable secure cookies
